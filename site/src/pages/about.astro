---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>À propos — Aquavena pour les malvoyants</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥗</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&display=swap" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <style>
    :root {
      --bg-page: #FFFBEB; --bg-card: #ffffff; --bg-card-alt: #FEF3C7;
      --bg-nav: #FFFBEB; --border: #FDE68A;
      --text-main: #1f2937; --text-muted: #374151;
    }
    [data-dark] {
      --bg-page: #1a1a2e; --bg-card: #16213e; --bg-card-alt: #0f3460;
      --bg-nav: #1a1a2e; --border: #2d3748;
      --text-main: #e2e8f0; --text-muted: #cbd5e0;
    }
    html { font-size: 18px; }
    body {
      font-family: 'Atkinson Hyperlegible', sans-serif;
      letter-spacing: 0.015em; line-height: 1.8;
      background-color: var(--bg-page); color: var(--text-main);
    }
    .card { background-color: var(--bg-card); border-color: var(--border); }
  </style>
</head>
<body>

  <header class="bg-teal-700 text-white shadow-md">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3 gap-3 flex-wrap">
      <div>
        <h1 class="text-lg font-bold leading-tight">À propos de ce site</h1>
        <p class="text-sm text-teal-100"><i class="fa-solid fa-eye-low-vision mr-1"></i>Optimisé pour les malvoyants</p>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <button id="btn-font-down" aria-label="Réduire la taille du texte"
          class="rounded-lg border border-teal-500 bg-teal-800 px-3 py-1 text-sm font-bold hover:bg-teal-600">A−</button>
        <button id="btn-font-up" aria-label="Agrandir la taille du texte"
          class="rounded-lg border border-teal-500 bg-teal-800 px-3 py-1 text-base font-bold hover:bg-teal-600">A+</button>
        <button id="btn-dark" aria-label="Basculer mode nuit"
          class="rounded-lg border border-teal-500 bg-teal-800 px-3 py-1 text-sm hover:bg-teal-600">
          <i class="fa-solid fa-moon" id="dark-icon"></i>
        </button>
        <a href="/aquavena/" class="rounded-lg border border-teal-500 bg-teal-800 px-4 py-2 text-sm font-bold hover:bg-teal-600">
          <i class="fa-solid fa-arrow-left mr-1"></i>Retour
        </a>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-2xl px-4 py-8 space-y-8">

    <section class="card rounded-2xl border-2 p-6 space-y-3"
      data-speech="Score d'accessibilité. Score AIM : 10 sur 10. Score obtenu avec l'outil AIM, Accessibility Insights for the Web, de Microsoft. Aucune erreur WAVE détectée. Structure, contraste, navigation au clavier et compatibilité lecteur d'écran sont validés.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-trophy mr-2 text-amber-500"></i>Score d'accessibilité</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <div class="flex items-center gap-4 flex-wrap">
        <div class="rounded-2xl bg-teal-600 px-8 py-4 text-center text-white shadow">
          <div class="text-5xl font-bold">10</div>
          <div class="text-sm">sur 10</div>
          <div class="text-xs text-teal-100 mt-1">Score AIM</div>
        </div>
        <p class="flex-1 text-base" style="color: var(--text-muted)">
          Score obtenu avec l'outil <strong>AIM (Accessibility Insights for the Web)</strong> de Microsoft.
          Aucune erreur WAVE détectée. Structure, contraste, navigation au clavier et
          compatibilité lecteur d'écran sont validés.
        </p>
      </div>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-4"
      data-speech="L'histoire du projet. Tout est parti d'une situation simple et concrète. Ma mère est cliente chez Aquavena — elle commande ses gamelles chaque semaine. Mais elle est malvoyante, et le site aquavena.nc, comme beaucoup de sites, n'est pas pensé pour les personnes qui ont des difficultés visuelles. Elle ne pouvait pas consulter les menus seule. Elle devait attendre que quelqu'un soit disponible pour lui lire à voix haute ce qu'elle mangerait dans la semaine. Ce petit manque d'autonomie, répété chaque semaine, m'a décidé. Si quelques heures de code pouvaient lui rendre ça — consulter ses menus seule, quand elle veut, depuis son téléphone — ça valait le coup. Ce site est un complément au site officiel, pas une alternative. Tout pointe vers aquavena.nc pour commander. L'idée est simplement d'offrir une porte d'entrée accessible aux personnes qui galèrent avec la mise en page habituelle. À Aquavena, si vous tombez sur ce site : il n'y a ici aucune compétition, aucune monétisation, aucun intérêt commercial. Juste la volonté qu'une personne malvoyante puisse profiter pleinement de votre service, en toute autonomie.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-heart mr-2 text-rose-500"></i>L'histoire du projet</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <p style="color: var(--text-muted)">
        Tout est parti d'une situation simple et concrète. Ma mère est cliente chez Aquavena —
        elle commande ses gamelles chaque semaine. Mais elle est malvoyante, et le site
        <a href="https://www.aquavena.nc" target="_blank" rel="noopener noreferrer" class="font-bold text-teal-700 hover:underline">aquavena.nc</a>,
        comme beaucoup de sites, n'est pas pensé pour les personnes qui ont des difficultés visuelles.
      </p>
      <p style="color: var(--text-muted)">
        Elle ne pouvait pas consulter les menus seule. Elle devait attendre que quelqu'un soit
        disponible pour lui lire à voix haute ce qu'elle mangerait dans la semaine.
        Ce petit manque d'autonomie, répété chaque semaine, m'a décidé.
      </p>
      <p style="color: var(--text-muted)">
        Si quelques heures de code pouvaient lui rendre ça — consulter ses menus seule, quand elle veut,
        depuis son téléphone — ça valait le coup.
      </p>
      <div class="rounded-2xl border-2 border-teal-200 bg-teal-50 p-5 space-y-2" style="color: var(--text-main)">
        <p class="font-bold text-teal-800"><i class="fa-solid fa-handshake mr-2"></i>Un mot pour l'équipe Aquavena</p>
        <p class="text-base" style="color: var(--text-muted)">
          Ce site est un <strong>complément</strong> au site officiel, pas une alternative.
          Chaque menu renvoie vers <a href="https://www.aquavena.nc" target="_blank" rel="noopener noreferrer" class="font-bold text-teal-700 hover:underline">aquavena.nc</a> pour commander.
          L'idée est simplement d'offrir une porte d'entrée accessible aux personnes qui galèrent
          avec la mise en page habituelle.
        </p>
        <p class="text-base" style="color: var(--text-muted)">
          Aucune compétition, aucune monétisation, aucun intérêt commercial.
          Juste la volonté qu'une personne malvoyante puisse profiter pleinement de votre service,
          en toute autonomie.
        </p>
      </div>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-3"
      data-speech="Pourquoi ce site ? Aquavena est un service de livraison de repas diététiques en Nouvelle-Calédonie. Leurs menus de la semaine sont publiés sur leur site, mais la mise en page n'est pas adaptée aux personnes ayant des difficultés visuelles. Ce site a été créé pour permettre à une personne malvoyante de consulter facilement les menus de la semaine, de les lire ou de les écouter, de manière autonome, sur téléphone, tablette ou ordinateur.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-circle-question mr-2 text-teal-600"></i>Pourquoi ce site ?</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <p style="color: var(--text-muted)">
        <a href="https://www.aquavena.nc" target="_blank" rel="noopener noreferrer" class="font-bold text-teal-700 hover:underline">Aquavena</a>
        est un service de livraison de repas diététiques en Nouvelle-Calédonie.
        Leurs menus de la semaine sont publiés sur leur site, mais la mise en page
        n'est pas adaptée aux personnes ayant des difficultés visuelles.
      </p>
      <p style="color: var(--text-muted)">
        Ce site a été créé pour permettre à une personne malvoyante de consulter
        facilement les menus de la semaine — de les lire, ou de les écouter —
        de manière autonome, sur téléphone, tablette ou ordinateur.
      </p>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-4"
      data-speech="Fonctionnalités d'accessibilité. Police Atkinson Hyperlegible, conçue spécifiquement pour les malvoyants, chaque lettre est distincte. Taille du texte réglable, boutons A plus et A moins pour ajuster selon le besoin. Mode nuit, fond sombre pour réduire la fatigue visuelle. Lecture à voix haute, chaque menu peut être lu par le navigateur. Lire toute la semaine, écouter tous les menus à la suite d'une seule pression. Flux RSS, s'abonner pour recevoir les menus dans un lecteur de flux. Contraste élevé, couleurs choisies pour respecter les normes WCAG AA. Structure sémantique, titres hiérarchisés pour une navigation facile avec les lecteurs d'écran.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-universal-access mr-2 text-teal-600"></i>Fonctionnalités d'accessibilité</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <ul class="space-y-3" style="color: var(--text-muted)">
        <li><i class="fa-solid fa-font mr-2 text-teal-500"></i><strong>Police Atkinson Hyperlegible</strong> — conçue spécifiquement pour les malvoyants, chaque lettre est distincte</li>
        <li><i class="fa-solid fa-text-height mr-2 text-teal-500"></i><strong>Taille du texte réglable</strong> — boutons A+ / A− pour ajuster selon le besoin</li>
        <li><i class="fa-solid fa-moon mr-2 text-teal-500"></i><strong>Mode nuit</strong> — fond sombre pour réduire la fatigue visuelle</li>
        <li><i class="fa-solid fa-volume-high mr-2 text-teal-500"></i><strong>Lecture à voix haute</strong> — chaque menu peut être lu par le navigateur (bouton Lire sur chaque jour)</li>
        <li><i class="fa-solid fa-headphones mr-2 text-teal-500"></i><strong>Lire toute la semaine</strong> — écouter tous les menus à la suite d'une seule pression</li>
        <li><i class="fa-solid fa-rss mr-2 text-teal-500"></i><strong>Flux RSS</strong> — s'abonner pour recevoir les menus dans un lecteur de flux</li>
        <li><i class="fa-solid fa-palette mr-2 text-teal-500"></i><strong>Contraste élevé</strong> — couleurs choisies pour respecter les normes WCAG AA (ratio 4,5:1 minimum)</li>
        <li><i class="fa-solid fa-heading mr-2 text-teal-500"></i><strong>Structure sémantique</strong> — titres hiérarchisés pour une navigation facile avec les lecteurs d'écran</li>
      </ul>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-3"
      data-speech="Comment ça fonctionne ? Les menus sont récupérés chaque soir automatiquement depuis aquavena.nc grâce à un SDK Python open source. Le site est ensuite reconstruit et publié sur GitHub Pages. Les données sont donc toujours à jour le lendemain matin. Le pipeline est le suivant : aquavena.nc, puis SDK Python, puis GitHub Actions, puis GitHub Pages.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-code mr-2 text-teal-600"></i>Comment ça fonctionne ?</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <p style="color: var(--text-muted)">
        Les menus sont récupérés chaque soir automatiquement depuis aquavena.nc
        grâce à un SDK Python open source. Le site est ensuite reconstruit et
        publié sur GitHub Pages — les données sont donc toujours à jour le lendemain matin.
      </p>
      <div class="rounded-xl bg-teal-50 border border-teal-200 p-4 text-sm font-mono" style="color: var(--text-main)">
        aquavena.nc → SDK Python → GitHub Actions → GitHub Pages
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="https://github.com/adriens/aquavena" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-gray-800 px-4 py-2 text-white font-bold hover:bg-gray-700 transition-colors">
          <i class="fa-brands fa-github"></i>Code source sur GitHub
        </a>
        <a href="https://pypi.org/project/aquavena-sdk/" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2 text-white font-bold hover:bg-blue-700 transition-colors">
          <i class="fa-brands fa-python"></i>Package PyPI
        </a>
      </div>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-4"
      data-speech="Flux RSS. Abonnez-vous aux flux RSS pour recevoir les menus automatiquement dans votre lecteur de flux préféré, comme Feedly ou NetNewsWire. Un flux global et un flux par régime sont disponibles. Pour s'abonner à un régime spécifique, cliquez sur l'icône RSS à côté du nom du régime sur la page principale.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-square-rss mr-2 text-orange-500"></i>Flux RSS</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <p style="color: var(--text-muted)">
        Abonnez-vous aux flux RSS pour recevoir les menus automatiquement dans votre lecteur de flux préféré
        (Feedly, NetNewsWire, etc.). Un flux global et un flux par régime sont disponibles.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/aquavena/feed.xml" class="inline-flex items-center gap-2 rounded-xl bg-orange-500 px-4 py-2 text-white font-bold hover:bg-orange-600 transition-colors">
          <i class="fa-solid fa-square-rss"></i>Tous les régimes
        </a>
      </div>
      <p class="text-sm" style="color: var(--text-muted)">
        Un flux par régime est aussi disponible — cliquez sur l'icône <i class="fa-solid fa-square-rss text-orange-500"></i> à côté du nom du régime sur la page principale.
      </p>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-4"
      data-speech="Calendriers iCal. Ajoutez les menus directement dans votre agenda, sur iPhone, Google Calendar ou Outlook. Chaque jour de menu apparaît comme un événement avec le détail Midi et Soir dans la description. Pour s'abonner sur iPhone ou iPad : allez dans Réglages, puis Calendrier, puis Comptes, puis Ajouter un compte, puis Autre, puis S'abonner à un calendrier, et collez l'URL du calendrier. Un calendrier par régime est aussi disponible depuis la page principale.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-calendar-plus mr-2 text-sky-500"></i>Calendriers iCal</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <p style="color: var(--text-muted)">
        Ajoutez les menus directement dans votre agenda (iPhone, Google Calendar, Outlook…).
        Chaque jour de menu apparaît comme un événement avec le détail Midi / Soir dans la description.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/aquavena/cal.ics" class="inline-flex items-center gap-2 rounded-xl bg-sky-500 px-4 py-2 text-white font-bold hover:bg-sky-600 transition-colors">
          <i class="fa-solid fa-calendar-plus"></i>Tous les régimes
        </a>
      </div>
      <div class="rounded-xl bg-sky-50 border border-sky-200 p-4 text-sm space-y-1" style="color: var(--text-main)">
        <p class="font-bold">S'abonner sur iPhone / iPad :</p>
        <p style="color: var(--text-muted)">Réglages → Calendrier → Comptes → Ajouter un compte → Autre → S'abonner à un calendrier → coller l'URL <code>.ics</code></p>
      </div>
      <p class="text-sm" style="color: var(--text-muted)">
        Un calendrier par régime est aussi disponible — cliquez sur l'icône <i class="fa-solid fa-calendar-plus text-sky-500"></i> à côté du nom du régime sur la page principale.
      </p>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-4"
      data-speech="Association pour les malvoyants en Nouvelle-Calédonie. L'association Valentin Haüy de Nouméa accompagne et soutient les personnes malvoyantes et aveugles en Nouvelle-Calédonie. Retrouvez leurs actualités, ressources et événements sur leur page Facebook.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-eye-low-vision mr-2 text-teal-600"></i>Malvoyants en Nouvelle-Calédonie</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <p style="color: var(--text-muted)">
        L'association <strong>Valentin Haüy de Nouméa</strong> accompagne et soutient les personnes
        malvoyantes et aveugles en Nouvelle-Calédonie. Retrouvez leurs actualités, ressources
        et événements sur leur page Facebook.
      </p>
      <a href="https://www.facebook.com/valentin.hauynoumea/?locale=fr_FR" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-5 py-3 text-white font-bold hover:bg-blue-700 transition-colors">
        <i class="fa-brands fa-facebook"></i>Valentin Haüy Nouméa
      </a>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-4"
      data-speech="Commander et contacter Aquavena. Aquavena. 13, rue de Charleroi, 98800 Nouméa, Nouvelle-Calédonie. Téléphone : 23 65 95. Site officiel : aquavena.nc. Facebook : Aquavena.nc. Instagram : aquavena.nc. Application Android disponible sur le Google Play Store.">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-cart-shopping mr-2 text-teal-600"></i>Commander chez Aquavena</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <div class="rounded-xl border border-gray-200 bg-gray-50 p-4 space-y-2 text-base" style="color: var(--text-main)">
        <p><i class="fa-solid fa-location-dot mr-2 text-teal-600"></i>13, rue de Charleroi, 98800 Nouméa — Nouvelle-Calédonie</p>
        <p>
          <a href="tel:+687236595" class="inline-flex items-center gap-2 font-bold text-teal-700 hover:underline">
            <i class="fa-solid fa-phone"></i>23 65 95
          </a>
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="https://www.aquavena.nc" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-teal-600 px-4 py-2 text-white font-bold hover:bg-teal-700 transition-colors">
          <i class="fa-solid fa-globe"></i>aquavena.nc
        </a>
        <a href="https://www.facebook.com/Aquavena.nc" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2 text-white font-bold hover:bg-blue-700 transition-colors">
          <i class="fa-brands fa-facebook"></i>Facebook
        </a>
        <a href="https://www.instagram.com/aquavena.nc/" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-pink-500 px-4 py-2 text-white font-bold hover:bg-pink-600 transition-colors">
          <i class="fa-brands fa-instagram"></i>Instagram
        </a>
        <a href="https://play.google.com/store/apps/details?id=webviewgold.aquavena&hl=fr" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-4 py-2 text-white font-bold hover:bg-green-700 transition-colors">
          <i class="fa-brands fa-google-play"></i>Application Android
        </a>
      </div>
    </section>

    <section class="card rounded-2xl border-2 p-6 space-y-3"
      data-speech="Interroger les menus avec Claude. Un serveur MCP, Model Context Protocol, est disponible sur Hugging Face Spaces. Il permet de poser des questions sur les menus directement à Claude, à l'écrit ou à la voix, sans ouvrir ce site. Par exemple : Qu'est-ce que je mange demain en régime méditerranéen ?">
      <h2 class="flex items-center justify-between text-2xl font-bold" style="color: var(--text-main)">
        <span><i class="fa-solid fa-robot mr-2 text-violet-600"></i>Interroger les menus avec Claude</span>
        <button class="speak-btn rounded-lg bg-teal-600 px-3 py-1 text-sm font-bold text-white hover:bg-teal-700" aria-label="Lire cette section à voix haute">
          <i class="fa-solid fa-volume-high mr-1"></i>Lire
        </button>
      </h2>
      <p style="color: var(--text-muted)">
        Un <strong>serveur MCP</strong> (Model Context Protocol) est disponible sur Hugging Face Spaces.
        Il permet de poser des questions sur les menus directement à Claude, à l'écrit ou à la voix —
        sans ouvrir ce site.
      </p>
      <p style="color: var(--text-muted)">
        Exemple : <em>"Qu'est-ce que je mange demain en régime méditerranéen ?"</em>
      </p>
      <a href="https://adriens.github.io/claude-commands/skills/aquavena/" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl bg-violet-600 px-5 py-3 text-white font-bold hover:bg-violet-700 transition-colors">
        <i class="fa-solid fa-robot"></i>Installer le skill Claude
      </a>
    </section>

  </main>

  <footer class="mt-12 border-t-2 py-6 text-center text-base text-gray-700" style="border-color: var(--border)">
    <p>
      <a href="https://www.aquavena.nc" target="_blank" rel="noopener noreferrer" class="hover:text-teal-800">aquavena.nc</a>
      {' · '}
      <a href="https://github.com/adriens/aquavena" target="_blank" rel="noopener noreferrer" class="hover:text-teal-800">
        <i class="fa-brands fa-github mr-1"></i>aquavena
      </a>
    </p>
  </footer>

  <script>
    // Font size
    function adjustFont(delta) {
      const cur = parseFloat(document.documentElement.style.fontSize) || 18;
      const next = Math.max(14, Math.min(28, cur + delta));
      document.documentElement.style.fontSize = next + 'px';
      try { localStorage.setItem('aq-fs', next); } catch {}
    }
    const storedFs = parseFloat(localStorage.getItem('aq-fs') || '18');
    document.documentElement.style.fontSize = storedFs + 'px';
    document.getElementById('btn-font-down').addEventListener('click', () => adjustFont(-2));
    document.getElementById('btn-font-up').addEventListener('click', () => adjustFont(2));

    // Dark mode
    function toggleDark() {
      const on = document.documentElement.hasAttribute('data-dark');
      if (on) { document.documentElement.removeAttribute('data-dark'); document.getElementById('dark-icon').className = 'fa-solid fa-moon'; localStorage.setItem('aq-dark','0'); }
      else    { document.documentElement.setAttribute('data-dark', ''); document.getElementById('dark-icon').className = 'fa-solid fa-sun';  localStorage.setItem('aq-dark','1'); }
    }
    if (localStorage.getItem('aq-dark') === '1') {
      document.documentElement.setAttribute('data-dark', '');
      document.getElementById('dark-icon').className = 'fa-solid fa-sun';
    }
    document.getElementById('btn-dark').addEventListener('click', toggleDark);

    let activeSpeakBtn = null;
    function speak(text, btn) {
      if (!window.speechSynthesis) return;
      if (window.speechSynthesis.speaking) {
        window.speechSynthesis.cancel();
        if (activeSpeakBtn) {
          activeSpeakBtn.innerHTML = '<i class="fa-solid fa-volume-high mr-1"></i>Lire';
        }
        if (activeSpeakBtn === btn) { activeSpeakBtn = null; return; }
      }
      const utter = new SpeechSynthesisUtterance(text);
      utter.lang = 'fr-FR';
      utter.rate = 0.9;
      const voices = window.speechSynthesis.getVoices();
      const frVoice = voices.find(v => v.lang.startsWith('fr'));
      if (frVoice) utter.voice = frVoice;
      utter.onstart = () => {
        activeSpeakBtn = btn;
        btn.innerHTML = '<i class="fa-solid fa-stop mr-1"></i>Stop';
      };
      utter.onend = utter.onerror = () => {
        btn.innerHTML = '<i class="fa-solid fa-volume-high mr-1"></i>Lire';
        activeSpeakBtn = null;
      };
      window.speechSynthesis.speak(utter);
    }
    document.querySelectorAll('.speak-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const section = btn.closest('section');
        if (section?.dataset.speech) speak(section.dataset.speech, btn);
      });
    });
  </script>

</body>
</html>
