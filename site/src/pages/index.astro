---
import menusData from '../data/menus.json';

const data = menusData as any;
const { generated_at, today, regimes } = data;
const genLabel: string = (generated_at as string).slice(0, 16).replace('T', ' ');

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  const s = d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
  return s.charAt(0).toUpperCase() + s.slice(1);
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aquavena — Menus de la semaine</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥗</text></svg>" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <style>
    .tabs::-webkit-scrollbar { display: none; }
    .tabs { scrollbar-width: none; -ms-overflow-style: none; }
  </style>
</head>
<body class="min-h-screen bg-amber-50 text-gray-800 text-lg">

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-teal-700 text-white shadow-md">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-5 py-4">
      <p class="text-lg font-bold">Aquavena — Menus de la semaine</p>
      <p class="font-mono text-sm text-teal-100 text-right">{genLabel}</p>
    </div>
  </header>

  <!-- Regime tabs -->
  <nav class="tabs sticky top-16 z-40 overflow-x-auto border-b-2 border-amber-200 bg-amber-50 shadow-sm">
    <div class="flex min-w-max">
      {regimes.map((r: any) => (
        <button
          data-slug={r.slug}
          class="tab-btn border-b-4 border-transparent px-5 py-4 text-base font-semibold whitespace-nowrap text-gray-600 transition-colors hover:border-teal-500 hover:text-teal-700"
        >
          {r.name}
        </button>
      ))}
    </div>
  </nav>

  <!-- Content panels -->
  <main class="mx-auto max-w-2xl px-4 py-6">
    {regimes.map((r: any) => {
      const days: any[] = r.menu?.days ?? [];
      const boissons: string[] = days[0]?.boissons ?? [];
      return (
        <section data-panel={r.slug} class="regime-panel hidden">
          {r.menu?.description && (
            <p class="mb-5 text-base italic text-gray-500 leading-relaxed">{r.menu.description}</p>
          )}

          {days.length > 0 ? (
            <div class="space-y-5">
              {days.filter((day: any) => day.date >= today).map((day: any) => {
                const isToday = day.date === today;
                const midi    = day.plats.filter((p: any) => p.meal_time === 'midi');
                const soir    = day.plats.filter((p: any) => p.meal_time === 'soir');
                const gourmet = day.plats.filter((p: any) => p.meal_time.startsWith('gourmet'));
                return (
                  <div
                    data-today={isToday ? 'true' : 'false'}
                    class={[
                      'overflow-hidden rounded-2xl border-2',
                      isToday
                        ? 'border-teal-400 shadow-lg ring-4 ring-teal-200'
                        : 'border-amber-200 shadow-sm',
                    ].join(' ')}
                  >
                    <!-- Card header: date en français -->
                    <div class={`px-5 py-4 ${isToday ? 'bg-teal-600 text-white' : 'bg-amber-100 text-gray-700'}`}>
                      <div class="flex items-center justify-between gap-2 flex-wrap">
                        <span class="text-2xl font-bold">{formatDate(day.date)}</span>
                        <div class="flex items-center gap-2">
                          {isToday && (
                            <span class="rounded-full bg-white px-3 py-1 text-sm font-bold text-teal-700">
                              Aujourd'hui
                            </span>
                          )}
                          {day.formule && (
                            <span class={`text-sm font-medium ${isToday ? 'text-teal-100' : 'text-gray-500'}`}>
                              {day.formule}
                            </span>
                          )}
                        </div>
                      </div>
                    </div>

                    <!-- Card body: blocs colorés par service -->
                    <div class="bg-white p-4 space-y-3">
                      {midi.length > 0 && (
                        <div class="rounded-xl bg-green-50 border border-green-200 p-4">
                          <p class="text-lg font-bold text-green-800 mb-2"><i class="fa-solid fa-sun mr-1"></i>Midi</p>
                          {midi.map((d: any) => (
                            <p class="text-xl leading-relaxed text-gray-800">{d.description}</p>
                          ))}
                        </div>
                      )}
                      {soir.length > 0 && (
                        <div class="rounded-xl bg-indigo-50 border border-indigo-200 p-4">
                          <p class="text-lg font-bold text-indigo-800 mb-2"><i class="fa-solid fa-moon mr-1"></i>Soir</p>
                          {soir.map((d: any) => (
                            <p class="text-xl leading-relaxed text-gray-800">{d.description}</p>
                          ))}
                        </div>
                      )}
                      {gourmet.length > 0 && (
                        <div class="rounded-xl bg-amber-50 border border-amber-200 p-4">
                          <p class="text-lg font-bold text-amber-800 mb-2"><i class="fa-solid fa-crown mr-1"></i>Gourmet</p>
                          {gourmet.map((d: any) => (
                            <p class="text-xl leading-relaxed text-gray-800">{d.description}</p>
                          ))}
                        </div>
                      )}
                      {day.supplements?.length > 0 && (
                        <div class="rounded-xl bg-gray-50 border border-gray-200 p-4">
                          <p class="text-lg font-bold text-gray-500 mb-2"><i class="fa-solid fa-plus mr-1"></i>Suppléments</p>
                          {day.supplements.map((s: string) => (
                            <p class="text-base text-gray-600 leading-relaxed">{s}</p>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}

              {boissons.length > 0 && (
                <div class="rounded-2xl border-2 border-sky-200 bg-sky-50 p-5">
                  <p class="mb-3 text-lg font-bold text-sky-800">
                    <i class="fa-solid fa-glass-water mr-1"></i>Boissons incluses
                  </p>
                  <div class="flex flex-wrap gap-3">
                    {boissons.map((b: string) => (
                      <span class="rounded-full bg-sky-100 px-4 py-2 text-base font-medium text-sky-900">{b}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ) : (
            <p class="py-16 text-center text-xl text-gray-400">Aucun menu disponible.</p>
          )}
        </section>
      );
    })}
  </main>

  <footer class="mt-12 border-t-2 border-amber-200 py-6 text-center text-base text-gray-400">
    <a href="https://www.aquavena.nc" target="_blank" rel="noopener noreferrer" class="hover:text-teal-600">aquavena.nc</a>
    {' · '}
    <a href="https://github.com/adriens/aquavena" target="_blank" rel="noopener noreferrer" class="hover:text-teal-600">aquavena-sdk</a>
  </footer>

  <script define:vars={{ slugs: regimes.map((r: any) => r.slug) }}>
    function showRegime(slug) {
      document.querySelectorAll('.regime-panel').forEach((el) => el.classList.add('hidden'));
      document.querySelectorAll('.tab-btn').forEach((btn) => {
        btn.classList.remove('border-teal-500', 'text-teal-700');
        btn.classList.add('border-transparent', 'text-gray-600');
      });

      const panel = document.querySelector(`[data-panel="${slug}"]`);
      if (panel) {
        panel.classList.remove('hidden');
        const todayCard = panel.querySelector('[data-today="true"]');
        if (todayCard) {
          requestAnimationFrame(() =>
            todayCard.scrollIntoView({ behavior: 'smooth', block: 'start' })
          );
        }
      }

      const tab = document.querySelector(`[data-slug="${slug}"]`);
      if (tab) {
        tab.classList.add('border-teal-500', 'text-teal-700');
        tab.classList.remove('border-transparent', 'text-gray-600');
        tab.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }

      try { localStorage.setItem('aq-regime', slug); } catch {}
    }

    document.querySelectorAll('.tab-btn').forEach((btn) => {
      btn.addEventListener('click', () => showRegime(btn.dataset.slug));
    });

    let saved;
    try { saved = localStorage.getItem('aq-regime'); } catch {}
    const initial = (saved && slugs.includes(saved)) ? saved : slugs[0];
    if (initial) showRegime(initial);
  </script>

</body>
</html>
