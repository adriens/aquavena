---
import menusData from '../data/menus.json';

const data = menusData as any;
const { today, regimes } = data;

const REGIME_ICONS: Record<string, string> = {
  'aqua-méditerranéen':    'fa-solid fa-sun',
  'aqua-chrono-diet':      'fa-solid fa-clock',
  'aqua-chrono-végé':      'fa-solid fa-seedling',
  'aqua-bien-être-family': 'fa-solid fa-heart',
  'aqua-gourmand':         'fa-solid fa-star',
  'aqua-végé':             'fa-solid fa-leaf',
  'aqua-low-carb':         'fa-solid fa-scale-balanced',
  'aquasportif':           'fa-solid fa-dumbbell',
  'la-boutique':           'fa-solid fa-bag-shopping',
};
function regimeIcon(slug: string): string {
  return REGIME_ICONS[slug] ?? 'fa-solid fa-utensils';
}
function toAsciiSlug(slug: string): string {
  return slug.normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9-]/g, '-');
}
function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00');
  const s = d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
  return s.charAt(0).toUpperCase() + s.slice(1);
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aquavena — Menus de la semaine (version malvoyants)</title>
  <link rel="alternate" type="application/rss+xml" title="Aquavena — Tous les régimes" href="/aquavena/feed.xml" />
  {regimes.map((r: any) => (
    <link rel="alternate" type="application/rss+xml" title={`Aquavena — ${r.name}`} href={`/aquavena/feed/${toAsciiSlug(r.slug)}.xml`} />
  ))}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🥗</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&display=swap" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <style>
    :root {
      --bg-page: #FFFBEB; --bg-card: #ffffff; --bg-card-alt: #FEF3C7;
      --bg-nav: #FFFBEB; --border: #FDE68A;
      --text-main: #1f2937; --text-muted: #374151;
    }
    [data-dark] {
      --bg-page: #1a1a2e; --bg-card: #16213e; --bg-card-alt: #0f3460;
      --bg-nav: #1a1a2e; --border: #2d3748;
      --text-main: #e2e8f0; --text-muted: #cbd5e0;
    }
    html { font-size: 18px; }
    body {
      font-family: 'Atkinson Hyperlegible', sans-serif;
      letter-spacing: 0.015em; line-height: 1.8;
      background-color: var(--bg-page); color: var(--text-main);
    }
    .card  { background-color: var(--bg-card); border-color: var(--border); }
    .card-alt { background-color: var(--bg-card-alt); }
    .nav-bg { background-color: var(--bg-nav); border-color: var(--border); }
    .tabs::-webkit-scrollbar { display: none; }
    .tabs { scrollbar-width: none; -ms-overflow-style: none; }
    details > summary { cursor: pointer; list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
  </style>
</head>
<body>

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-teal-700 text-white shadow-md">
    <div class="mx-auto flex max-w-4xl items-center justify-between px-4 py-3 gap-3 flex-wrap">
      <div>
        <h1 class="text-lg font-bold leading-tight">Aquavena — Menus de la semaine</h1>
        <p class="text-sm text-teal-100"><i class="fa-solid fa-eye-low-vision mr-1"></i>Optimisé pour les malvoyants</p>
      </div>
      <div class="flex items-center gap-2">
        <!-- A+ / A- -->
        <button id="btn-font-down" aria-label="Réduire la taille du texte"
          class="rounded-lg border border-teal-500 bg-teal-800 px-3 py-1 text-sm font-bold hover:bg-teal-600">A−</button>
        <button id="btn-font-up" aria-label="Agrandir la taille du texte"
          class="rounded-lg border border-teal-500 bg-teal-800 px-3 py-1 text-base font-bold hover:bg-teal-600">A+</button>
        <!-- Mode nuit -->
        <button id="btn-dark" aria-label="Basculer mode nuit"
          class="rounded-lg border border-teal-500 bg-teal-800 px-3 py-1 text-sm hover:bg-teal-600">
          <i class="fa-solid fa-moon" id="dark-icon"></i>
        </button>
      </div>
    </div>
  </header>

  <!-- Regime tabs -->
  <nav class="tabs nav-bg sticky top-16 z-40 overflow-x-auto border-b-2" aria-label="Régimes alimentaires">
    <div class="flex min-w-max">
      {regimes.map((r: any) => (
        <button
          data-slug={r.slug}
          aria-label={`Afficher le régime ${r.name}`}
          class="tab-btn border-b-4 border-transparent px-5 py-4 text-base font-semibold whitespace-nowrap text-gray-700 transition-colors hover:border-teal-600 hover:text-teal-800"
        >
          <i class={`${regimeIcon(r.slug)} mr-1.5`}></i>{r.name}
        </button>
      ))}
    </div>
  </nav>

  <!-- Content panels -->
  <main class="mx-auto max-w-2xl px-4 py-6">
    {regimes.map((r: any) => {
      const days: any[] = r.menu?.days ?? [];
      const boissons: string[] = days[0]?.boissons ?? [];
      const tarifs: any[] = r.tarifs ?? [];
      return (
        <section data-panel={r.slug} class="regime-panel hidden">
          <h2 class="text-xl font-bold mb-3" style="color: var(--text-main)">
            <i class={`${regimeIcon(r.slug)} mr-2`}></i>{r.name}
            <a href={`/aquavena/feed/${toAsciiSlug(r.slug)}.xml`} aria-label={`Flux RSS ${r.name}`}
              class="ml-3 text-orange-500 hover:text-orange-700 text-base align-middle">
              <i class="fa-solid fa-square-rss"></i>
            </a>
            <a href={`/aquavena/cal/${toAsciiSlug(r.slug)}.ics`} aria-label={`Calendrier iCal ${r.name}`}
              class="ml-2 text-sky-500 hover:text-sky-700 text-base align-middle">
              <i class="fa-solid fa-calendar-plus"></i>
            </a>
          </h2>
          {r.menu?.description && (
            <p class="mb-5 text-base italic leading-relaxed" style="color: var(--text-muted)">{r.menu.description}</p>
          )}

          {days.length > 0 && (
            <button class="speak-week-btn mb-5 flex items-center gap-2 rounded-xl bg-teal-600 px-5 py-3 text-lg font-bold text-white shadow hover:bg-teal-700 transition-colors"
              aria-label="Lire tous les menus de la semaine à voix haute">
              <i class="fa-solid fa-volume-high"></i>Lire toute la semaine
            </button>
          )}

          {days.length > 0 ? (
            <div class="space-y-5">
              {days.filter((day: any) => day.date >= today).map((day: any) => {
                const isToday = day.date === today;
                const midi    = day.plats.filter((p: any) => p.meal_time === 'midi');
                const soir    = day.plats.filter((p: any) => p.meal_time === 'soir');
                const gourmet = day.plats.filter((p: any) => p.meal_time.startsWith('gourmet'));
                const speechParts: string[] = [`Menus du ${formatDate(day.date)}, régime ${r.name}.`];
                if (midi.length)             speechParts.push(`Midi : ${midi.map((d: any) => d.description).join(', ')}.`);
                if (soir.length)             speechParts.push(`Soir : ${soir.map((d: any) => d.description).join(', ')}.`);
                if (gourmet.length)          speechParts.push(`Gourmet : ${gourmet.map((d: any) => d.description).join(', ')}.`);
                if (day.supplements?.length) speechParts.push(`Suppléments : ${day.supplements.join(', ')}.`);
                return (
                  <article
                    data-today={isToday ? 'true' : 'false'}
                    data-speech={speechParts.join(' ')}
                    class={`card overflow-hidden rounded-2xl border-2 ${isToday ? 'border-teal-400 shadow-lg ring-4 ring-teal-200' : 'shadow-sm'}`}
                  >
                    <div class={`flex items-center justify-between px-5 py-3 flex-wrap gap-2 ${isToday ? 'bg-teal-600 text-white' : 'card-alt'}`}
                      style={!isToday ? 'color: var(--text-main)' : ''}>
                      <h3 class="text-2xl font-bold">{formatDate(day.date)}</h3>
                      <div class="flex items-center gap-2">
                        {isToday && <span class="rounded-full bg-white px-3 py-1 text-sm font-bold text-teal-700">Aujourd'hui</span>}
                        {day.formule && <span class={`text-sm font-medium ${isToday ? 'text-white' : ''}`} style={!isToday ? 'color: var(--text-muted)' : ''}>{day.formule}</span>}
                        <button class="speak-btn rounded-lg px-3 py-1 text-sm font-bold transition-colors"
                          class:list={[isToday ? 'bg-white text-teal-700 hover:bg-teal-50' : 'bg-teal-600 text-white hover:bg-teal-700']}
                          aria-label="Lire le menu à voix haute">
                          <i class="fa-solid fa-volume-high mr-1"></i>Lire
                        </button>
                      </div>
                    </div>
                    <div class="p-4 space-y-3">
                      {midi.length > 0 && (
                        <div class="rounded-xl border border-green-200 bg-green-50 p-4">
                          <h4 class="text-lg font-bold text-green-800 mb-2"><i class="fa-solid fa-sun mr-1"></i>Midi</h4>
                          {midi.map((d: any) => <p class="text-xl leading-relaxed text-gray-800">{d.description}</p>)}
                        </div>
                      )}
                      {soir.length > 0 && (
                        <div class="rounded-xl border border-indigo-200 bg-indigo-50 p-4">
                          <h4 class="text-lg font-bold text-indigo-800 mb-2"><i class="fa-solid fa-moon mr-1"></i>Soir</h4>
                          {soir.map((d: any) => <p class="text-xl leading-relaxed text-gray-800">{d.description}</p>)}
                        </div>
                      )}
                      {gourmet.length > 0 && (
                        <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
                          <h4 class="text-lg font-bold text-amber-800 mb-2"><i class="fa-solid fa-crown mr-1"></i>Gourmet</h4>
                          {gourmet.map((d: any) => <p class="text-xl leading-relaxed text-gray-800">{d.description}</p>)}
                        </div>
                      )}
                      {day.supplements?.length > 0 && (
                        <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                          <h4 class="text-lg font-bold text-gray-700 mb-2"><i class="fa-solid fa-plus mr-1"></i>Suppléments</h4>
                          {day.supplements.map((s: string) => <p class="text-base leading-relaxed text-gray-800">{s}</p>)}
                        </div>
                      )}
                    </div>
                  </article>
                );
              })}

              {boissons.length > 0 && (
                <div class="rounded-2xl border-2 border-sky-200 bg-sky-50 p-5">
                  <h4 class="mb-3 text-lg font-bold text-sky-800"><i class="fa-solid fa-glass-water mr-1"></i>Boissons incluses</h4>
                  <div class="flex flex-wrap gap-3">
                    {boissons.map((b: string) => <span class="rounded-full bg-sky-100 px-4 py-2 text-base font-medium text-sky-900">{b}</span>)}
                  </div>
                </div>
              )}

              {tarifs.length > 0 && (
                <div class="rounded-2xl border-2 border-amber-200 bg-white px-5 py-4">
                  <h4 class="text-lg font-bold text-gray-800 mb-3"><i class="fa-solid fa-tag mr-2 text-amber-600"></i>Tarifs</h4>
                  <table class="w-full text-base">
                    <thead>
                      <tr class="border-b-2 border-amber-200">
                        <th class="text-left py-2 text-gray-700 font-bold">Formule</th>
                        <th class="text-right py-2 text-gray-700 font-bold">TTC (XPF)</th>
                      </tr>
                    </thead>
                    <tbody>
                      {tarifs.map((t: any) => (
                        <tr class="border-b border-amber-100">
                          <td class="py-2 text-gray-800 leading-relaxed">{t.label}</td>
                          <td class="py-2 text-right font-bold text-teal-700">{t.price_ttc.toLocaleString('fr-FR')} XPF</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          ) : (
            <p class="py-16 text-center text-xl text-gray-600">Aucun menu disponible.</p>
          )}
        </section>
      );
    })}
  </main>

  <footer class="mt-12 border-t-2 py-6 text-center text-base space-y-2" style="border-color: var(--border); color: var(--text-muted)">
    <p>
      <a href="https://www.aquavena.nc" target="_blank" rel="noopener noreferrer" class="hover:text-teal-600" style="color: var(--text-muted)">aquavena.nc</a>
      {' · '}
      <a href="https://github.com/adriens/aquavena" target="_blank" rel="noopener noreferrer" class="hover:text-teal-600" style="color: var(--text-muted)"><i class="fa-brands fa-github mr-1"></i>aquavena</a>
      {' · '}
      <a href="/aquavena/about/" class="hover:text-teal-600" style="color: var(--text-muted)"><i class="fa-solid fa-circle-question mr-1"></i>À propos</a>
      {' · '}
      <a href="https://adriens.github.io/claude-commands/skills/aquavena/" target="_blank" rel="noopener noreferrer" class="hover:text-violet-600" style="color: var(--text-muted)"><i class="fa-solid fa-robot mr-1"></i>Skill Claude</a>
    </p>
    <p class="text-sm" style="color: var(--text-muted)">
      <i class="fa-solid fa-eye-low-vision mr-1"></i>Site optimisé pour les malvoyants — police <span class="italic">Atkinson Hyperlegible</span>
      — <i class="fa-solid fa-universal-access mr-1"></i>Score d'accessibilité AIM : <strong>10 / 10</strong>
    </p>
    <p>
      <a href="/aquavena/feed.xml" class="inline-flex items-center gap-1 hover:text-orange-500" style="color: var(--text-muted)">
        <i class="fa-solid fa-square-rss text-orange-500 text-xl"></i>
        <span class="text-sm">Flux RSS — tous les régimes</span>
      </a>
      <span class="mx-1" style="color: var(--text-muted)">·</span>
      <a href="/aquavena/cal.ics" class="inline-flex items-center gap-1 hover:text-sky-500" style="color: var(--text-muted)">
        <i class="fa-solid fa-calendar-plus text-sky-500 text-xl"></i>
        <span class="text-sm">Calendrier iCal — tous les régimes</span>
      </a>
    </p>
  </footer>

  <script define:vars={{ slugs: regimes.map((r: any) => r.slug) }}>
    // Font size — on change html font-size so rem-based Tailwind classes scale
    function adjustFont(delta) {
      const cur = parseFloat(document.documentElement.style.fontSize) || 18;
      const next = Math.max(14, Math.min(28, cur + delta));
      document.documentElement.style.fontSize = next + 'px';
      try { localStorage.setItem('aq-fs', next); } catch {}
    }
    const storedFs = parseFloat(localStorage.getItem('aq-fs') || '18');
    document.documentElement.style.fontSize = storedFs + 'px';
    document.getElementById('btn-font-down').addEventListener('click', () => adjustFont(-2));
    document.getElementById('btn-font-up').addEventListener('click', () => adjustFont(2));

    // Dark mode
    function toggleDark() {
      const on = document.documentElement.hasAttribute('data-dark');
      if (on) { document.documentElement.removeAttribute('data-dark'); document.getElementById('dark-icon').className = 'fa-solid fa-moon'; localStorage.setItem('aq-dark','0'); }
      else    { document.documentElement.setAttribute('data-dark', ''); document.getElementById('dark-icon').className = 'fa-solid fa-sun';  localStorage.setItem('aq-dark','1'); }
    }
    if (localStorage.getItem('aq-dark') === '1') {
      document.documentElement.setAttribute('data-dark', '');
      document.getElementById('dark-icon').className = 'fa-solid fa-sun';
    }
    document.getElementById('btn-dark').addEventListener('click', toggleDark);

    // Tabs
    function showRegime(slug) {
      document.querySelectorAll('.regime-panel').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('border-teal-500', 'text-teal-800');
        btn.classList.add('border-transparent', 'text-gray-700');
      });
      const panel = document.querySelector(`[data-panel="${slug}"]`);
      if (panel) {
        panel.classList.remove('hidden');
        const todayCard = panel.querySelector('[data-today="true"]');
        if (todayCard) requestAnimationFrame(() => todayCard.scrollIntoView({ behavior: 'smooth', block: 'start' }));
      }
      const tab = document.querySelector(`[data-slug="${slug}"]`);
      if (tab) {
        tab.classList.add('border-teal-500', 'text-teal-800');
        tab.classList.remove('border-transparent', 'text-gray-700');
        tab.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
      try { localStorage.setItem('aq-regime', slug); } catch {}
    }

    // Text-to-speech
    let activeSpeakBtn = null;
    function speak(text, btn) {
      if (!window.speechSynthesis) return;
      if (window.speechSynthesis.speaking) {
        window.speechSynthesis.cancel();
        if (activeSpeakBtn) {
          activeSpeakBtn.innerHTML = '<i class="fa-solid fa-volume-high mr-1"></i>Lire';
          activeSpeakBtn.disabled = false;
        }
        if (activeSpeakBtn === btn) { activeSpeakBtn = null; return; }
      }
      const utter = new SpeechSynthesisUtterance(text);
      utter.lang = 'fr-FR';
      utter.rate = 0.9;
      const voices = window.speechSynthesis.getVoices();
      const frVoice = voices.find(v => v.lang.startsWith('fr'));
      if (frVoice) utter.voice = frVoice;
      utter.onstart = () => {
        activeSpeakBtn = btn;
        btn.innerHTML = '<i class="fa-solid fa-stop mr-1"></i>Stop';
        btn.disabled = false;
      };
      utter.onend = utter.onerror = () => {
        btn.innerHTML = '<i class="fa-solid fa-volume-high mr-1"></i>Lire';
        btn.disabled = false;
        activeSpeakBtn = null;
      };
      window.speechSynthesis.speak(utter);
    }
    document.querySelectorAll('.speak-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const article = btn.closest('article');
        if (article?.dataset.speech) speak(article.dataset.speech, btn);
      });
    });

    // "Lire toute la semaine"
    function speakWeek(btn) {
      if (!window.speechSynthesis) return;
      if (window.speechSynthesis.speaking) {
        window.speechSynthesis.cancel();
        btn.innerHTML = '<i class="fa-solid fa-volume-high"></i>Lire toute la semaine';
        btn.disabled = false;
        if (activeSpeakBtn) { activeSpeakBtn.innerHTML = '<i class="fa-solid fa-volume-high mr-1"></i>Lire'; activeSpeakBtn = null; }
        return;
      }
      const panel = btn.closest('section');
      const texts = [...panel.querySelectorAll('article[data-speech]')].map(a => a.dataset.speech);
      if (!texts.length) return;
      btn.innerHTML = '<i class="fa-solid fa-stop"></i>Stop';
      btn.disabled = false;
      let i = 0;
      function next() {
        if (i >= texts.length) {
          btn.innerHTML = '<i class="fa-solid fa-volume-high"></i>Lire toute la semaine';
          return;
        }
        const utter = new SpeechSynthesisUtterance(texts[i++]);
        utter.lang = 'fr-FR';
        utter.rate = 0.9;
        const voices = window.speechSynthesis.getVoices();
        const frVoice = voices.find(v => v.lang.startsWith('fr'));
        if (frVoice) utter.voice = frVoice;
        utter.onend = next;
        utter.onerror = () => { btn.innerHTML = '<i class="fa-solid fa-volume-high"></i>Lire toute la semaine'; };
        window.speechSynthesis.speak(utter);
      }
      next();
    }
    document.querySelectorAll('.speak-week-btn').forEach(btn => {
      btn.addEventListener('click', () => speakWeek(btn));
    });

    document.querySelectorAll('.tab-btn').forEach(btn => btn.addEventListener('click', () => showRegime(btn.dataset.slug)));

    let saved; try { saved = localStorage.getItem('aq-regime'); } catch {}
    const defaultSlug = slugs.find(s => s.includes('méditerran')) ?? slugs[0];
    const initial = (saved && slugs.includes(saved)) ? saved : defaultSlug;
    if (initial) showRegime(initial);
  </script>

</body>
</html>
